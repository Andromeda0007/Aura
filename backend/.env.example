# ---- Aura backend environment (example) ----
# Copy to `.env` and fill values. NEVER commit the real `.env`.

# Database (matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg://aura:aura@localhost:5432/aura_db

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# Free LLM providers (Groq primary, Gemini fallback)
GROQ_API_KEY=
GEMINI_API_KEY=

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Context compression
COMPRESSION_TOKEN_LIMIT=10000

# Runtime
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
